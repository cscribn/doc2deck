# Optional: path to gemini CLI (defaults to "gemini" on PATH)
# GEMINI_CLI_PATH=gemini

# Optional paths (defaults shown)
SOURCE_PPTX_PATH=source.pptx
SOURCE_DOCX_PATH=source.docx
OUTPUT_PPTX_PATH=final_presentation.pptx

# Optional Gemini CLI settings
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_MAX_RETRIES=3
