# Optional: path to gemini CLI (defaults to "gemini" on PATH)
# GEMINI_CLI_PATH=gemini

# Presentation key instructions (copy presentation-keys.example.properties to presentation-keys.properties)
# PRESENTATION_KEYS_PATH=presentation-keys.properties

# Voice and tone (default: neutral professional style)
# VOICE_STYLE_PATH=prompts/voice-styles/neutral.md
# VOICE_STYLE_PATH=prompts/voice-styles/tedx.md
# LAYOUT_STATIC_SLIDE_INDICES=0,5,8

# Optional paths (defaults shown)
TEMPLATE_PPTX_PATH=template.pptx
SOURCES_DIR=sources
OUTPUT_PPTX_PATH=final_presentation.pptx

# Optional Gemini CLI settings
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_MAX_RETRIES=3

# Optional Pexels API for slide images (get a free key at https://www.pexels.com/api/)
# PEXELS_API_KEY=your_pexels_api_key
# IMAGE_CACHE_DIR=.cache/images

# Optional image optimization (applied to all embedded pictures before final write)
# IMAGE_JPEG_QUALITY=0.8
# IMAGE_OPTIMIZATION_ENABLED=true

# Optional unused embedded font removal before final write
# FONT_CLEANUP_ENABLED=true

# Optional layout normalization for Google Drive / Google Slides compatibility
# LAYOUT_NORMALIZE_ENABLED=true
